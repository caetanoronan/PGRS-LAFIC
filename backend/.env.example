# Notion API Configuration
NOTION_API_KEY=your_notion_api_key_here
NOTION_DATABASE_ID_WASTE=your_waste_inventory_database_id
NOTION_DATABASE_ID_BIOSECURITY=your_biosecurity_database_id
NOTION_DATABASE_ID_INACTIVATION=your_inactivation_protocol_database_id
NOTION_DATABASE_ID_ALERTS=your_alerts_database_id
NOTION_DATABASE_ID_MAINTENANCE=your_maintenance_database_id

# Server Configuration
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Database
DATABASE_PATH=./data/alerts.db

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
